# Fleet API Keys
# Copy this file to .env and fill in your keys.
# Add to your shell profile (~/.zshrc or ~/.bashrc) with: source ~/.env
# Never commit the real .env file — it's in .gitignore.

# Required: Anthropic Claude (fleet orchestration, judgment, final review)
export ANTHROPIC_API_KEY="sk-ant-..."

# Optional: Gemini 2.5 Flash (token-saving mid-tier for research, summarization, drafting)
# Get your key at: https://aistudio.google.com/apikey
# Usage: GEMINI_API_KEY=$GEMINI_API_KEY gemini -p "your prompt" -y
export GEMINI_API_KEY=""

# Optional: NVIDIA NIM (134 models under one key — code gen, classification, specialized tasks)
# Get your key at: https://build.nvidia.com
# Usage: curl https://integrate.api.nvidia.com/v1/chat/completions -H "Authorization: Bearer $NVIDIA_API_KEY" ...
export NVIDIA_API_KEY=""

# Optional: Fleet Hive (docs/18-fleet-hive.md) — a LiteLLM gateway + parallel orchestrator.
# HIVE_MASTER_KEY is read by the gateway (launch-gateway.sh); HIVE_KEY is read by hive.py
# callers — set both to the SAME secret string. Groq/Cerebras keys are only needed if you
# enable those lanes in scripts/hive/gateway-config.yaml.
export HIVE_MASTER_KEY=""
export HIVE_KEY=""
# Get a Groq key at: https://console.groq.com/keys (free, no credit card)
export GROQ_API_KEY=""
# Get a Cerebras key at: https://cloud.cerebras.ai (free tier, no credit card)
export CEREBRAS_API_KEY=""

# Optional: Telegram bot token (for fleet notifications)
# Get from @BotFather on Telegram
export TELEGRAM_BOT_TOKEN=""
export TELEGRAM_CHAT_ID=""

# Optional: Session board tuning
# SESSION_STALE_MIN=15        # minutes before a board entry is flagged stale (default 15)
# SESSION_PRUNE_HOURS=4       # hours before a dead-process entry is auto-removed from the board (default 4)

# Optional: Override the machine name used for inbox routing
# Default: hostname -s (your machine's short hostname)
# Must match your inbox filename: inbox/<FLEET_MACHINE_NAME>.md
export FLEET_MACHINE_NAME=""
